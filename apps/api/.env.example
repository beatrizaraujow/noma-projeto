# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/noma"
MONGODB_URI="mongodb://localhost:27017/noma"         # opcional
REDIS_URL="redis://localhost:6379"                   # opcional
ELASTICSEARCH_NODE="http://localhost:9200"           # opcional

# ─── JWT ─────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=sua-chave-secreta-forte-aqui
JWT_EXPIRATION=7d

# ─── Google OAuth (opcional) ─────────────────────────────────
# Crie em https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── OpenAI (opcional) ───────────────────────────────────────
OPENAI_API_KEY=
