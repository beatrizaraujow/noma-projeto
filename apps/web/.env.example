# ─── API ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Gere com: openssl rand -base64 64
NEXTAUTH_SECRET=sua-chave-secreta-forte-aqui

# ─── Google OAuth (opcional) ─────────────────────────────────
# Crie em https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
